# Copy to `.env.local` in this folder (gitignored). Vite exposes only names starting with VITE_.
# Values load when localStorage is empty for that setting (new port/profile) and sync into the browser on first run.

# VITE_LM_STUDIO_BASE_URL=http://localhost:8080

# VITE_DEEPSEEK_API_KEY=
# VITE_GROK_API_KEY=
# VITE_CEREBRAS_API_KEY=
# VITE_TOGETHER_API_KEY=
# VITE_DEEPINFRA_API_KEY=
# VITE_BRAVE_API_KEY=

# VITE_TOGETHER_IMAGE_ENDPOINT=
